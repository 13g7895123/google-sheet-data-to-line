# Google Sheet to LINE 推播系統 — 環境變數範例
# 複製此檔案為 .env 並填入實際數值
# cp .env.example .env

# ─── Docker 對外 Port ─────────────────────────────────────────────────────────
# 前端管理介面對外暴露的 port（宿主機 port → 容器內 Nginx port 80）
FRONTEND_PORT=8080

# ─── LINE Messaging API ──────────────────────────────────────────────────────
# 從 LINE Developers Console 取得
# 若不填，可在系統啟動後透過管理介面「設定」頁載入
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ─── Google Service Account ───────────────────────────────────────────────────
# client_email（來自下載的 JSON 金鑰）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# private_key（完整字串，含 BEGIN/END PRIVATE KEY 標頭）
# 注意：多行字串需用雙引號包住，換行以 \n 表示
# 範例：GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=
